{
  "name": "VectorClaw Dev",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.debugpy"
      ]
    }
  },
  "postCreateCommand": "python -m pip install --upgrade pip && pip install -e .[dev]",
  "remoteUser": "vscode"
}
